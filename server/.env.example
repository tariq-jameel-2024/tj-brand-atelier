# Copy this file to .env and fill values before running the server
# Example values (do NOT commit real tokens to source control)

# A random string you choose for webhook verification in Meta Developer Console
VERIFY_TOKEN=replace_with_a_random_string

# WhatsApp Cloud API permanent token (from Meta Business Manager)
WHATSAPP_TOKEN=EAA...YOUR_WHATSAPP_TOKEN

# Facebook Page / Messenger Page Access Token (for Messenger / IG via Messenger API)
PAGE_ACCESS_TOKEN=EAA...YOUR_PAGE_TOKEN

# Optional: override the default welcome message
WELCOME_MESSAGE=Welcome to TJ Brand Atelier — we are happy to assist you.

# Port to run server on
PORT=3000
